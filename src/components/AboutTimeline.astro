---
import { resolveProjectTimeline } from "@utils/github-projects";
import { Icon } from "astro-icon/components";
import { projectTimeline } from "../content/projects";

const resolvedTimeline = await resolveProjectTimeline(projectTimeline);
const isGitHubProject = (url: string) => url.startsWith("https://github.com/");
const getGitHubOwner = (url: string) => {
	if (!isGitHubProject(url)) return undefined;
	return new URL(url).pathname.split("/")[1] || undefined;
};
const getTagIcon = (tag: string) =>
	tag.startsWith("icon:") ? tag.slice("icon:".length) : undefined;
---

<section class="about-timeline">
	<ol>
		{resolvedTimeline.map((entry) => (
			<li id={`year-${entry.year}`}>
				<a class="timeline-year" href={`#year-${entry.year}`} aria-label={`定位到 ${entry.year} 年项目`}>
					<span>{entry.year}</span>
					{entry.suffix && <small>{entry.suffix}</small>}
				</a>
				<div class="timeline-content">
					{entry.sections.map((section) => (
						<section class="timeline-section">
							<div class="timeline-section-heading">
								<h3>{section.title}</h3>
								{section.tech && section.tech.length > 0 && <span class="project-tech section-tech" aria-label={`技术栈：${section.tech.join("、")}`}>
									{section.tech.map((item) => getTagIcon(item)
										? <span class="project-tech-icon" title={getTagIcon(item)} aria-label="技术图标"><Icon name={getTagIcon(item)!} aria-hidden="true" /></span>
										: <span>{item}</span>)}
								</span>}
							</div>
							<p class="whitespace-pre-line">{section.description}</p>
							{section.projects.length > 0 && <div class="project-grid">
							{section.projects.map((project) => (
							<a class="project-card" href={project.url} target="_blank" rel="noreferrer">
								<span class="project-title">
									{getGitHubOwner(project.url) && getGitHubOwner(project.url) !== "orangeboyChen" && <span class="project-owner"><Icon name="fa6-brands:github" aria-hidden="true" />{getGitHubOwner(project.url)}</span>}
									<span class="project-name">{project.name}</span>
									{project.tech.length > 0 && <span class="project-tech" aria-label={`技术栈：${project.tech.join("、")}`}>
										{project.tech.map((item) => getTagIcon(item)
											? <span class="project-tech-icon" title={getTagIcon(item)} aria-label="技术图标"><Icon name={getTagIcon(item)!} aria-hidden="true" /></span>
											: <span>{item}</span>)}
									</span>}
								</span>
								<span class="project-description">{project.description}</span>
								{isGitHubProject(project.url) && <Icon class="project-github" name="fa6-brands:github" aria-label="GitHub 项目" />}
							</a>
								))}
							</div>}
						</section>
					))}
				</div>
			</li>
		))}
	</ol>
</section>

<style>
	.about-timeline {
		margin-top: 0;
		font-size: inherit;
	}

	.about-timeline > ol {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.about-timeline > ol > li {
		display: grid;
		grid-template-columns: 6.5em minmax(0, 1fr);
		gap: 0.85em;
		padding-bottom: 2.5em;
		scroll-margin-top: 6rem;
	}

	.about-timeline > ol > li:last-child {
		padding-bottom: 0;
	}

	.timeline-year {
		position: relative;
		padding: 0.16em 0 0 1.2em;
		color: var(--primary);
		font-family: "JetBrains Mono", monospace;
		font-size: 1.08em;
		font-weight: 700;
		text-decoration: none;
		transition: color 150ms ease;
	}

	.timeline-year:hover {
		color: var(--btn-content);
	}

	.timeline-year:focus-visible {
		border-radius: 0.25em;
		outline: 3px solid var(--primary);
		outline-offset: 3px;
	}

	.timeline-year > span,
	.timeline-year > small {
		display: block;
	}

	.timeline-year > small {
		margin-top: 0.12em;
		font-size: 0.62em;
		font-weight: 600;
		letter-spacing: 0.04em;
	}

	.timeline-year::before {
		position: absolute;
		top: 0.48em;
		left: 0;
		width: 0.52em;
		height: 0.52em;
		border: 0.16em solid var(--card-bg);
		border-radius: 999px;
		background: var(--primary);
		box-shadow: 0 0 0 1px var(--primary);
		content: "";
	}

	.timeline-year::after {
		position: absolute;
		top: 1em;
		bottom: -3em;
		left: 0.26em;
		width: 1px;
		background: var(--line-divider);
		content: "";
	}

	.about-timeline > ol > li:last-child .timeline-year::after {
		display: none;
	}

	.timeline-section + .timeline-section {
		margin-top: 2.5em;
		padding-top: 2.5em;
		border-top: 1px solid var(--line-divider);
	}

	.timeline-section h3 {
		margin: 0;
		color: var(--deep-text);
		font-size: 1.25em;
		font-weight: 700;
	}

	.timeline-section-heading {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.65em;
	}

	.timeline-section > p {
		margin: 0.4em 0 1em;
		color: var(--deep-text);
		font-size: 1em;
		line-height: 1.7;
		opacity: 0.72;
	}

	.project-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: 0.6em;
	}

	.project-card {
		position: relative;
		display: grid;
		gap: 0.35em;
		min-height: 6.2em;
		padding: 1em 3em 1em 1.2em;
		border-radius: var(--radius-large);
		background: var(--license-block-bg);
		color: var(--deep-text);
		text-decoration: none;
		transition: background-color 150ms ease, transform 150ms ease;
	}

	.project-card:hover {
		background: var(--btn-regular-bg-hover);
	}

	.project-card:hover .project-title,
	.project-card:hover .project-description {
		color: var(--btn-content);
		opacity: 1;
	}

	.project-card:active {
		background: var(--btn-regular-bg-active);
		transform: scale(0.98);
	}

	.project-card:focus-visible {
		outline: 3px solid var(--primary);
		outline-offset: 3px;
	}

	.project-name {
		color: var(--deep-text);
		font-size: 0.95em;
		font-weight: 700;
		line-height: 1.35;
	}

	.project-owner {
		display: inline-flex;
		align-items: center;
		gap: 0.35em;
		color: var(--deep-text);
		font-size: 0.86em;
		font-weight: 400;
		opacity: 0.62;
	}

	.project-owner :global(svg) {
		font-size: 1em;
	}

	.project-title {
		display: inline-flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.65em;
		color: var(--deep-text);
		font-size: 1.05em;
		line-height: 1.35;
	}

	.project-github {
		position: absolute;
		top: 1.1em;
		right: 1.2em;
		color: var(--deep-text);
		font-size: 1.1em;
		opacity: 0.75;
	}

	.project-description {
		color: var(--deep-text);
		font-size: 0.95em;
		line-height: 1.5;
		opacity: 0.72;
	}

	.project-tech {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45em;
		margin: 0;
	}

	.project-tech > span {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.2em;
		border-radius: 0.55em;
		background: var(--btn-regular-bg);
		color: var(--btn-content);
		font-family: "JetBrains Mono", monospace;
		font-size: 0.74em;
		font-weight: 600;
		line-height: 1.2;
		padding: 0.3em 0.6em;
	}

	.project-tech > .project-tech-icon {
		min-width: 2.2em;
		padding: 0.3em;
	}

	.project-tech-icon :global(svg) {
		font-size: 1.25em;
	}

	@media (max-width: 38rem) {
		.about-timeline > ol > li {
			grid-template-columns: 1fr;
			gap: 0.65em;
		}

		.timeline-year::after {
			display: none;
		}

		.project-tech {
			flex-basis: 100%;
			margin: 0 0 0 -4px;
		}

		.project-title {
			column-gap: 0.65em;
			row-gap: 0.45em;
		}

		.project-card {
			gap: 0.7em;
		}

	}

	@media (prefers-reduced-motion: reduce) {
		.project-card {
			transition: none;
		}
	}
</style>
